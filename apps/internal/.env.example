APP_BASE_URL=http://localhost:3000
NODE_ENV=development

################
#    RESEND    #
################

RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=portal@notifications.placetostandagency.com
RESEND_REPLY_TO_EMAIL=hello@placetostandagency.com


########################
#   LEADS INTEGRATION   #
########################

LEADS_INTAKE_TOKEN=


################
#    VERCEL    #
################

AI_GATEWAY_API_KEY=


################
#   SUPABASE   #
################

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


################
#    STRIPE    #
################

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


###############
#   POSTHOG   #
###############

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
DISABLE_POSTHOG_UPLOAD_SOURCEMAPS=true


################
#    OAUTH     #
################

# OAuth Token Encryption (generate with: openssl rand -base64 32)
OAUTH_TOKEN_ENCRYPTION_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Google service account for reading transcripts on behalf of any workspace user.
# Requires domain-wide delegation to be configured in Google Admin Console for
# the service account's client ID, with scope: drive.readonly.
# GOOGLE_SERVICE_ACCOUNT_KEY is the full JSON key file contents (stringified, single line).
# GOOGLE_WORKSPACE_IMPERSONATION_SUBJECT is the email of a workspace user to impersonate
# (typically a shared mailbox or admin account). Both must be set to enable.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_WORKSPACE_IMPERSONATION_SUBJECT=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github
